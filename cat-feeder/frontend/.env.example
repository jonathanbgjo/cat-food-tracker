# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Whisker (Litter-Robot) account — used server-side to sync cat weights.
# Same email/password you use in the Whisker app. Never exposed to the browser.
WHISKER_EMAIL=
WHISKER_PASSWORD=

# Telegram — "cats are overdue" alerts (free). Create a bot with @BotFather for
# the token, then get your chat id (see README).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Shared secret to protect the schedule-check endpoint (the cron passes ?key=...).
CRON_SECRET=
